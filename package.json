{
	"name": "buenos_cakes",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "pnpm dev:web:ensure",
		"dev:e2e": "pnpm dev:web:e2e:ensure",
		"dev:web": "next dev --hostname localhost --port 3000",
		"dev:web:ensure": "bash -lc 'if curl -sfI http://localhost:3000 >/dev/null; then echo \"[web] Reusing existing app at http://localhost:3000.\"; exec tail -f /dev/null; else pnpm dev:web; fi'",
		"dev:web:e2e": "NEXT_DIST_DIR=.next-e2e next dev --hostname localhost --port 3101",
		"dev:web:e2e:ensure": "bash -lc 'if curl -sfI http://localhost:3101 >/dev/null; then echo \"[web] Reusing existing e2e app at http://localhost:3101.\"; exec tail -f /dev/null; else pnpm dev:web:e2e; fi'",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.100.14",
		"axios": "^1.16.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"lucide-react": "^0.577.0",
		"motion": "^12.35.0",
		"next": "16.1.6",
		"nuqs": "^2.8.9",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-day-picker": "^9.14.0",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.71.2",
		"react-resizable-panels": "^4.7.2",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitest/ui": "^4.1.0",
		"jsdom": "^28.1.0",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
